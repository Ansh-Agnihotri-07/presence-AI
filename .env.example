# ─── Presence AI Environment Variables ───

# ══ COST SAFETY ══
FREE_MODE=true
ALLOW_PAID_MODELS=false
MAX_CALLS_PER_DAY=100

# ══ LOCAL AI (Ollama — auto-detected) ══
LOCAL_MODEL=llama3:8b
OLLAMA_HOST=http://localhost:11434

# ══ GROQ (speed engine) ══
GROQ_API_KEY=your_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ══ GEMINI (deep reasoning engine) ══
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.0-flash

# ══ CLOUD AI (OpenRouter — legacy fallback) ══
MODEL_LOCK=meta-llama/llama-3.1-8b-instruct:free
OPENAI_API_KEY=your_key_here
OPENAI_API_BASE=https://openrouter.ai/api/v1

# ══ LLM Defaults ══
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# ══ Voice (optional) ══
VOICE_ENABLED=false
WHISPER_MODEL=base
TTS_VOICE=en-US-AriaNeural

# ══ UI ══
ORB_SIZE=80
ORB_OPACITY=0.85
CHAT_HOTKEY=ctrl+space

# ══ Scheduler ══
CHECKIN_INTERVAL_MINUTES=60
NUDGE_ENABLED=true

# ══ Tesseract OCR (optional) ══
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
